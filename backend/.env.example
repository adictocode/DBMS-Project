# ================================================================
#  ONLINE VOTING SYSTEM — Environment Variables
# ================================================================
#  Copy this file to `.env` and fill in your actual values.
#  NEVER commit the real `.env` file to version control.
# ================================================================

# --- Flask ---
FLASK_SECRET_KEY=change-me-to-a-random-secret-string
FLASK_DEBUG=True

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=online_voting_system

# --- AI Agent Integration (Future) ---
# Uncomment and configure when integrating a GenAI agent
# for real-time audit log anomaly detection.
# AI_AGENT_WEBHOOK_URL=http://localhost:8000/agent/webhook
# AI_AGENT_API_KEY=your_agent_api_key_here
